{
  "version": 2,
  "functions": {
    "api/auth/send-meeting-log.js": {
      "maxDuration": 30
    },
    "api/auth/send-otp.js": {
      "maxDuration": 15
    },
    "api/auth/send-reset-code.js": {
      "maxDuration": 15
    },
    "api/auth/send-invite.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
